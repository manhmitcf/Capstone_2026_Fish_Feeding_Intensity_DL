{
  "epochs": 500,
  "batch_size": 64,
  "learning_rate": 1e-3,
  "monitor": "accuracy",
  "early_stopping": true,
  "patience": 100,
  "delta": 0.0,
  "cache_audio": true,
  "dataset_splitter": {
    "dataset_path": "/marimo/audio",
    "seed": 25,
    "test_sample_per_class": 700,
    "save_results": true,
    "include_video": true
  },
  "audio_features": {
    "sample_rate": 64000,
    "window_size": 2048,
    "hop_size": 1024,
    "mel_bins": 128,
    "fmin": 1,
    "fmax": 128000,
    "time_drop_width": 64,
    "time_stripes_num": 2,
    "freq_drop_width": 8,
    "freq_stripes_num": 2
  }
}